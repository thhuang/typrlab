{
  "name": "typr",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "An adaptive typing trainer that drills your weakest keys and transitions.",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
